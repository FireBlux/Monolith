2]},{"code":401,"indent":2,"parameters":["\\n<Elovia>Edgar Allan Poe..."]},{"code":101,"indent":2,"parameters":["Eloviafaceset",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Elovia>I learnt about him in school once."]},{"code":230,"indent":2,"parameters":[60]},{"code":101,"indent":2,"parameters":["Eloviafaceset",7,0,2]},{"code":401,"indent":2,"parameters":["\\n<Elovia>(That was the year I got kicked out...)"]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"Exit"]},{"code":117,"indent":2,"parameters":[202]},{"code":113,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":413,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":6,"y":5},
