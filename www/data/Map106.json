{"id":2,"name":"Terminal","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":112,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["Select an entry:"]},{"code":102,"indent":1,"parameters":[["Entry #1","Entry #2","Exit"],1,0,2,0]},{"code":402,"indent":1,"parameters":[0,"Entry #1"]},{"code":117,"indent":2,"parameters":[214]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["The following is a recovered terminal entry:"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["It’s not easy, being so limited by those around me."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["But it’s good to know that my endowment for amphibious robotics is not going unnoticed by those in the lower floors."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["I’ve worked so hard for the day where my devotion to this place will finally be given its rightful spot, and I will be there with the director."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["That wonderful day will make trudging through the rabble all worth it."]},{"code":117,"indent":2,"parameters":[215]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"Entry #2"]},{"code":117,"indent":2,"parameters":[214]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["The following is an archived conversation transcript:"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>Hey, Maren? I was wondering if you could help me with the pipes-"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Maren>Why would I help you?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>I..."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Maren>Every second I spend helping you is a second that could be used working on my own projects."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Maren>The director personally thanked me for my contributions today. Look? On the terminal."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>Well, that doesn’t really mean anything. Do you even know their name?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Maren>No one does. Except those on floor X, I reckon."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>That’s where you’re going, then?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Maren>That’s where we all want to go."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Maren>Except you, apparently."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>No! Of course I-"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Maren>Then you should stop distracting me from my project and get back to work, hmm? Or do you want to be stuck here in G forever?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>...No. You're right."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["[Door closing]"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Maren>I don't know who's worse, her or that Holly woman she keeps on talking to."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Maren>Petulant literature, or insipid prying?"]},{"code":117,"indent":2,"parameters":[215]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[2,"Exit"]},{"code":117,"indent":2,"parameters":[202]},{"code":113,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":413,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":4},
{"id":3,"name":"EV003","note":"Maren's Old Room","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":117,"indent":0,"parameters":[250]},{"code":250,"indent":0,"parameters":[{"name":"Electrocardiogram","volume":90,"pitch":100,"pan":0}]},{"code":250,"indent":0,"parameters":[{"name":"Electrocardiogram","volume":90,"pitch":130,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["The robot sparks to life at a touch."]},{"code":121,"indent":0,"parameters":[174,174,0]},{"code":101,"indent":0,"parameters":["Eloviafaceset",6,0,2]},{"code":401,"indent":0,"parameters":["\\n<Elovia>I got this one."]},{"code":101,"indent":0,"parameters":["Yurasafaceset2",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<Yurasa>Wait, wait, wait!"]},{"code":101,"indent":0,"parameters":["Yurasafaceset",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<Yurasa>I think it's not LUCI's."]},{"code":230,"indent":0,"parameters":[60]},{"code":117,"indent":0,"parameters":[202]},{"code":117,"indent":0,"parameters":[138]},{"code":101,"indent":0,"parameters":["Stevefaceset1",2,0,2]},{"code":401,"indent":0,"parameters":["\\n<Robot>Greetings, Ms. Nathaira.\\.\\. What task would you have me complete today?"]},{"code":230,"indent":0,"parameters":[60]},{"code":117,"indent":0,"parameters":[136]},{"code":101,"indent":0,"parameters":["Eloviafaceset",1,0,2]},{"code":401,"indent":0,"parameters":["\\n<Elovia>...What should we do with it, then?"]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["Yurasafaceset",6,0,2]},{"code":401,"indent":0,"parameters":["\\n<Yurasa>What should I call you?"]},{"code":117,"indent":0,"parameters":[138]},{"code":101,"indent":0,"parameters":["Stevefaceset1",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<Robot>Designation: Amphibious Maintenance Unit v2.503 dash epsilon."]},{"code":117,"indent":0,"parameters":[136]},{"code":101,"indent":0,"parameters":["Yurasafaceset",6,0,2]},{"code":401,"indent":0,"parameters":["\\n<Yurasa>No, I think you deserve better."]},{"code":101,"indent":0,"parameters":["Yurasafaceset",6,0,2]},{"code":401,"indent":0,"parameters":["\\n<Yurasa>New designation..."]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["Yurasafaceset",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<Yurasa>I got it. Subnautical Steve."]},{"code":117,"indent":0,"parameters":[138]},{"code":101,"indent":0,"parameters":["Stevefaceset1",1,0,2]},{"code":401,"indent":0,"parameters":["\\n<Robot>New designation: \"Subnautical Steve\". Confirmed."]},{"code":230,"indent":0,"parameters":[60]},{"code":117,"indent":0,"parameters":[136]},{"code":101,"indent":0,"parameters":["Yurasafaceset",4,0,2]},{"code":401,"indent":0,"parameters":["\\n<Yurasa>C'mon now, Subnautical Steve."]},{"code":117,"indent":0,"parameters":[138]},{"code":101,"indent":0,"parameters":["Stevefaceset1",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<Subnautical Steve>Understood."]},{"code":101,"indent":0,"parameters":["Stevefaceset1",2,0,2]},{"code":401,"indent":0,"parameters":["\\n<Subnautical Steve>I am ready to help in any way you need."]},{"code":250,"indent":0,"parameters":[{"name":"Electrocardiogram","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[60]},{"code":250,"indent":0,"parameters":[{"name":"Electrocardiogram","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["Stevefaceset1",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<Subnautical Steve>Thank you both for allowing yourselves to be bio-scanned for tracking purposes."]},{"code":117,"indent":0,"parameters":[136]},{"code":101,"indent":0,"parameters":["Eloviafaceset",1,0,2]},{"code":401,"indent":0,"parameters":["\\n<Elovia>\"Bio-scan\"? I thought people couldn't do things like that to others unless they were given permission."]},{"code":117,"indent":0,"parameters":[138]},{"code":101,"indent":0,"parameters":["Stevefaceset1",0,0,2]},{"code":401,"indent":0,"parameters":["\\n<Subnautical Steve>I am not a person."]},{"code":230,"indent":0,"parameters":[120]},{"code":117,"indent":0,"parameters":[136]},{"code":101,"indent":0,"parameters":["Eloviafaceset2",4,0,2]},{"code":401,"indent":0,"parameters":["\\n<Elovia>You got me there."]},{"code":117,"indent":0,"parameters":[226]},{"code":121,"indent":0,"parameters":[160,160,0]},{"code":126,"indent":0,"parameters":[304,0,0,1]},{"code":121,"indent":0,"parameters":[174,174,1]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\\ii[304] x1 Obtained."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":160,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":4,"y":5},
