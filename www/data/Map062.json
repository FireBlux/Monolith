,"parameters":["One day I'll get Alex himself. Then everything will be set like I want it to."]},{"code":117,"indent":2,"parameters":[196]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[2,"Entry #3"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["The following is an archived message from: [N/A]"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Greetings. You have been given access to level X. Please report there as soon as possible tomorrow. You are required."]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[3,"Exit"]},{"code":117,"indent":2,"parameters":[202]},{"code":113,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":413,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":4,"y":7},
