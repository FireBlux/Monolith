{"id":9,"name":"EV009","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":112,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["Select an entry to view:"]},{"code":102,"indent":1,"parameters":[["Entry #1","Entry #2","Entry #3","Entry #4","Exit"],1,0,2,0]},{"code":402,"indent":1,"parameters":[0,"Entry #1"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Outgoing message to: [HIDDEN] (7 attached files)<br>"]},{"code":401,"indent":2,"parameters":["Hello,<br>"]},{"code":401,"indent":2,"parameters":["Apologies for the interruption, Z.\\.\\. I wanted to discuss potentially integrating your excellent LUCI project into the Fabricators around the facility."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["I believe that automating these will prove to be a boon to the company.<br>"]},{"code":401,"indent":2,"parameters":["Attached are some documents with further details.<br>"]},{"code":401,"indent":2,"parameters":["Your brother, E"]},{"code":117,"indent":2,"parameters":[196]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"Entry #2"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Reply from: [HIDDEN]<br>"]},{"code":401,"indent":2,"parameters":["With all due respect, E, your persistence in believing you understand the scale of the LUCI project is beginning to tire me.<br>"]},{"code":401,"indent":2,"parameters":["I have repeatedly told you that the project's development time is devoted to other sectors - ones that are far beyond your current jurisdiction."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["I have already been complacent with your previous screw-ups due to you being family.\\.\\. Misuse time on suggestions like these again and I will not hesitate to replace you with someone more adequate."]},{"code":117,"indent":2,"parameters":[196]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[2,"Entry #3"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Outgoing message to: Myself<br>"]},{"code":401,"indent":2,"parameters":["Check in with Doctor Amai, Tuesdays 12:00<br>"]},{"code":401,"indent":2,"parameters":["Phone follow-up, Wednesdays 15:00<br>"]},{"code":401,"indent":2,"parameters":["Visit pharmacy by next Tuesday"]},{"code":117,"indent":2,"parameters":[196]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[3,"Entry #4"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Outgoing message to: [HIDDEN]<br>"]},{"code":401,"indent":2,"parameters":["Z,<br>"]},{"code":401,"indent":2,"parameters":["Please, this cannot go on.\\.\\. Your devotion to your project's beginning to worry me."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["You haven't visited mum with me and Felicia in two years now.<br>"]},{"code":401,"indent":2,"parameters":["You're always my sister to me, which is why I'm telling you to take some time off work for once."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Regards,<br>"]},{"code":401,"indent":2,"parameters":["-E"]},{"code":101,"indent":2,"parameters":["Eloviafaceset3",3,0,2]},{"code":401,"indent":2,"parameters":["\\n<Elovia>..."]},{"code":117,"indent":2,"parameters":[196]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[4,"Exit"]},{"code":205,"indent":2,"parameters":[-1,{"list":[{"code":13,"indent":null},{"code"