ameters":["\\n<Subnautical Steve>Muse.\\.\\. Noun.\\.\\. A person or force that is a source of inspiration for an artist."]},{"code":101,"indent":2,"parameters":["Stevefaceset1",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Subnautical Steve>Alternative definition: a collection of goddesses of art and science in Greek religion."]},{"code":117,"indent":2,"parameters":[136]},{"code":101,"indent":2,"parameters":["Eloviafaceset",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Elovia>You're quite handy."]},{"code":117,"indent":2,"parameters":[138]},{"code":101,"indent":2,"parameters":["Stevefaceset1",1,0,2]},{"code":401,"indent":2,"parameters":["\\n<Subnautical Steve>My creator, Maren Natharia, was sagacious on the matters of A.I. and amphibious robotics."]},{"code":117,"indent":2,"parameters":[136]},{"code":101,"indent":2,"parameters":["Eloviafaceset",1,0,2]},{"code":401,"indent":2,"parameters":["\\n<Elovia>Did she program you to say that?"]},{"code":117,"indent":2,"parameters":[138]},{"code":101,"indent":2,"parameters":["Stevefaceset1",1,0,2]},{"code":401,"indent":2,"parameters":["\\n<Subnautical Steve>Correct."]},{"code":117,"indent":2,"parameters":[136]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"Entry #2"]},{"code":117,"indent":2,"parameters":[214]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["The following is an archived conversation transcript:"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>Yeah! We got promoted!"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Holly>All the way to level J, no less!"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>I knew your habit of picking up gossip could get us that boost, Holly."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Holly>We'll catch up to Maren together at this rate."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Alex>What, that robot hugger? Dunno why you'd wanna hang around her."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Holly>Not sure how you got promoted to J alongside us, Alex."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Holly>Whenever I see you, you're always listening to music."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Alex>Cause it lifts my vibes up, Holly, man."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Alex>It's like... that glass elevator from the story of Waldo's chocolate factory, y'know."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>Wonka's."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Alex>Bless ya, Ju-lie."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Julie>I hate how I laughed at that."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Holly>Point is, distractions like that won't work if you wanna get to the top, Alex."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Alex>Why wouldn't I wanna distract myself? This place sucks."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Holly>...But it's better than living elsewhere."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\n<Alex>I think that's the firs' thing you and I agreed on, Holly."]},{"code":117,"indent":2,"parameters":[215]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[2,"Exit"]},{"code":117,"indent":2,"parameters":[202]},{"code":113,"indent":2,"parame