{"id":3,"name":"Terminal","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":112,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["Select an entry:"]},{"code":102,"indent":1,"parameters":[["Entry #1","Entry #2","Exit"],3,0,2,0]},{"code":402,"indent":1,"parameters":[0,"Entry #1"]},{"code":117,"indent":2,"parameters":[214]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["The following is [ERROR]"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["All divisions of technology have stagnated in recent years, but none as much as aerospce."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Once, man would compete to see who could reach the moon first. Now, it struggles to see past the clouds."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[8]Dimensional Energy\\c[0] is the key. This downscaled prototype is but one of many developed here at Arc-Tec."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["With the power contained in \\c[8]Dimensional Energy\\c[0], we shall turn science fiction into fact."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Blessed am I to be in possession of such a muse; one without equal."]},{"code":117,"indent":2,"parameters":[215]},{"code":101,"indent":2,"parameters":["Yurasafaceset3",5,0,2]},{"code":401,"indent":2,"parameters":["\\n<Yurasa>Sounds like a real weirdo, don't you think, Elovia?"]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"Entry #2"]},{"code":117,"indent":2,"parameters":[214]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["The following is an archived message from: [ERROR]"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Next Wednesday, at noon, I plan to host a demonstration of our new technology's power."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["Take this prototype up to the marked location before then. Take care not to activate it; a launch inside the facility will lead to damages that you cannot hope to afford, I assure you."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["You have had a number of shortcomings as supervisor of G floor, and have been reported to display argumentative behaviour towards the new LUCI system."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["However, I believe there is still much benefit to be had from your contributions."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["You have been given access to level X. Please report there as soon as possible after delivering the prototype. It is required."]},{"code":117,"indent":2,"parameters":[215]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[2,"Exit"]},{"code":205,"indent":2,"parameters":[-1,{"list":[{"code":1,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":2,"parameters":[{"code":1,"indent":null}]},{"code":113,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":413,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveS